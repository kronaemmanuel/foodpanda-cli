{
  "name": "foodpanda-pk-cli",
  "version": "0.1.0",
  "description": "CLI for ordering food from foodpanda.pk — designed for AI assistants",
  "type": "module",
  "bin": {
    "foodpanda-pk-cli": "./build/cli.js"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "dev": "node ./node_modules/typescript/bin/tsc --watch",
    "start": "node build/cli.js",
    "prepublishOnly": "npm run build"
  },
  "files": ["build"],
  "keywords": ["foodpanda", "food-delivery", "ai-assistant", "cli", "pakistan", "multan"],
